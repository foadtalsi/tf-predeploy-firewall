{
  "_comment": "Curated map of resource_type -> attributes that are ForceNew in the AWS provider schema (changing them triggers destroy+recreate). Extend as coverage grows.",
  "aws_db_instance": ["identifier", "identifier_prefix", "engine", "username", "availability_zone", "storage_type", "license_model", "allocated_storage_type", "snapshot_identifier"],
  "aws_instance": ["ami", "availability_zone", "subnet_id", "tenancy", "user_data", "user_data_base64"],
  "aws_ebs_volume": ["availability_zone", "snapshot_id", "encrypted", "size"],
  "aws_elasticache_cluster": ["cluster_id", "engine", "node_type", "subnet_group_name", "az_mode"],
  "aws_s3_bucket": ["bucket", "bucket_prefix"],
  "aws_dynamodb_table": ["name", "hash_key", "range_key"],
  "aws_vpc": ["cidr_block", "instance_tenancy"],
  "aws_subnet": ["vpc_id", "cidr_block", "availability_zone", "availability_zone_id"],
  "aws_security_group": ["name", "name_prefix", "vpc_id"],
  "aws_kms_key": ["customer_master_key_spec", "key_usage"]
}
